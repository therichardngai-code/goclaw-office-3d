# GoClaw Office 3D — Environment Variables
# Copy to .env and fill in the required values before running docker compose.
#
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────

# Gateway auth token — used by the 3D UI to authenticate with GoClaw.
# Generate a secure random value:  openssl rand -hex 32
GOCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Encryption key for API keys stored in the database (AES-256-GCM).
# Must be exactly 32 bytes (64 hex characters):  openssl rand -hex 32
GOCLAW_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# ── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL credentials (defaults are fine for local dev)
POSTGRES_USER=goclaw
POSTGRES_PASSWORD=goclaw
POSTGRES_DB=goclaw

# ── Ports ─────────────────────────────────────────────────────────────────────

# 3D Office UI — http://localhost:8080
WEB3D_PORT=8080

# Web Dashboard (agents, channels, providers, logs) — http://localhost:3000
GOCLAW_UI_PORT=3000

# GoClaw API (optional direct access) — http://localhost:18790
GOCLAW_API_PORT=18790
